              "    pm.expect(jsonData[0].Category).to.equal(\"Schmoceries\");",
              "});",
              "",
              "pm.test(\"value of [0].Price to be 42\", () => {",
              "    pm.expect(jsonData[0].Price).to.equal(42);",
              "});",
              "",
              "pm.test(\"value of [1].Id to be 2\", () => {",
